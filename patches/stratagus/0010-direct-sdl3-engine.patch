+		title, width, height, static_cast<SDL_WindowFlags>(flags));
+	if (window != nullptr && x != SDL_WINDOWPOS_UNDEFINED
+	    && y != SDL_WINDOWPOS_UNDEFINED
+	    && !SDL_SetWindowPosition(window, x, y)) {
+		SDL_DestroyWindow(window);
+		return nullptr;
+	}
+	return window;
+#else
+	return SDL_CreateWindow(
